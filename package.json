{
  "author": {
    "email": "daniel@honestempire.com",
    "name": "Daniel Morris",
    "url": "https://unfun.co"
  },
  "bugs": {
    "url": "https://github.com/unfunco/prettier-plugin-yaml/issues"
  },
  "description": "YAML plugin for Prettier that avoids indentation of sequence values.",
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/node": "24.12.2",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "jiti": "2.6.1",
    "prettier": "3.8.2",
    "tsup": "8.5.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/unfunco/prettier-plugin-yaml#readme",
  "keywords": [
    "prettier",
    "prettier-plugin",
    "sequence",
    "yaml"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "name": "@unfunco/prettier-plugin-yaml",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unfunco/prettier-plugin-yaml"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm && tsc -p tsconfig.build.json",
    "fmt:check": "prettier --check .",
    "fmt:fix": "prettier --write .",
    "lint:check": "eslint",
    "lint:fix": "eslint",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "0.3.1"
}
